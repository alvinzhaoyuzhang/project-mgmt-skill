{
  "_warning_filter_field_types": "⚠️ 飞书角色 filter_rules 不支持以下字段类型:lookup / formula / link(单向或双向) / auto_number / created_time / modified_time / created_by / updated_by / 双向关联。如需基于这些字段做权限过滤,改造成 select / text / number 等基础字段,由 skill 写入时主动同步。详见 references/feishu-permission-limits.md。bootstrap.sh 在创建角色前会跑 _validate_role.py 自动校验。",
  "role_name": "项目经理",
  "role_type": "custom_role",
  "base_rule_map": {"copy": false, "download": true},
  "table_rule_map": {
    "项目主表": {
      "perm": "edit",
      "view_rule": {"allow_edit": false, "visibility": {"all_visible": true}},
      "field_rule": {"field_perm_mode": "all_edit"},
      "record_rule": {
        "record_operations": ["add"],
        "edit_filter_rule_group": {
          "conjunction": "and",
          "filter_rules": [
            {"conjunction": "and", "filters": [{"field_name": "项目经理", "operator": "contains"}]}
          ]
        },
        "other_record_all_read": true
      }
    },
    "任务表": {
      "perm": "edit",
      "view_rule": {"allow_edit": false, "visibility": {"all_visible": true}},
      "field_rule": {"field_perm_mode": "all_edit"},
      "record_rule": {
        "record_operations": ["add", "delete"],
        "other_record_all_read": true
      }
    },
    "速查卡·字段分级权限": {
      "perm": "read_only",
      "view_rule": {"allow_edit": false, "visibility": {"all_visible": true}},
      "field_rule": {"field_perm_mode": "all_read"},
      "record_rule": {"record_operations": [], "other_record_all_read": true}
    }
  }
}
