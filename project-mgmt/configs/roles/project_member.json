{
  "role_name": "项目成员",
  "role_type": "custom_role",
  "base_rule_map": {"copy": false, "download": false},
  "table_rule_map": {
    "项目主表": {
      "perm": "read_only",
      "view_rule": {"allow_edit": false, "visibility": {"all_visible": true}},
      "field_rule": {"field_perm_mode": "all_read"},
      "record_rule": {
        "record_operations": [],
        "other_record_all_read": false,
        "read_filter_rule_group": {
          "conjunction": "and",
          "filter_rules": [
            {"conjunction": "and", "filters": [{"field_name": "项目成员", "operator": "contains"}]}
          ]
        }
      }
    },
    "任务表": {
      "perm": "edit",
      "view_rule": {"allow_edit": false, "visibility": {"all_visible": true}},
      "field_rule": {"field_perm_mode": "all_edit"},
      "record_rule": {
        "record_operations": ["add"],
        "edit_filter_rule_group": {
          "conjunction": "or",
          "filter_rules": [
            {"conjunction": "and", "filters": [{"field_name": "负责人", "operator": "contains"}]},
            {"conjunction": "and", "filters": [{"field_name": "协作人", "operator": "contains"}]}
          ]
        },
        "other_record_all_read": false,
        "read_filter_rule_group": {
          "conjunction": "or",
          "filter_rules": [
            {"conjunction": "and", "filters": [{"field_name": "项目保密等级", "operator": "contains", "filter_values": ["L1 公开", "L2 常规"]}]},
            {"conjunction": "and", "filters": [{"field_name": "负责人", "operator": "contains"}]},
            {"conjunction": "and", "filters": [{"field_name": "协作人", "operator": "contains"}]}
          ]
        }
      }
    },
    "速查卡·字段分级权限": {
      "perm": "read_only",
      "view_rule": {"allow_edit": false, "visibility": {"all_visible": true}},
      "field_rule": {"field_perm_mode": "all_read"},
      "record_rule": {"record_operations": [], "other_record_all_read": true}
    }
  }
}
